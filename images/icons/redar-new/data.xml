<!DOCTYPE codename-engine-icon>
<icon scale="0.95" facing="right" antialiasing="true" offsetX="15" offsetY="15">
    <anim name="neutral" anim="idle0" looped="true" fps="24"/>
    <anim name="losing" anim="losing0" looped="true" fps="24"/>
    <anim name="winning" anim="winning0" looped="true" fps="24"/>

    <transition from="neutral" to="losing" anim="toLosing0" fps="24"/>
    <transition from="losing" to="neutral" anim="fromLosing0" fps="24"/>
    <transition from="neutral" to="winning" anim="toWinning0" fps="24"/>
    <transition from="winning" to="neutral" anim="fromWinning0" fps="24"/>
</icon>